// api/submit-review.js
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
const supabaseServiceKey = process.env.SUPABASE_SERVICE_ROLE_KEY; // secret

const supabase = createClient(supabaseUrl, supabaseServiceKey);

export default async function handler(req, res) {
  if (req.method === "OPTIONS") {
    res.status(200).end();
    return;
  }

  if (req.method !== "POST") {
    res.status(405).json({ error: "Method not allowed" });
    return;
  }

  try {
    let payload = req.body;
    if (typeof payload === "string") {
      payload = JSON.parse(payload || "{}");
    }

    const { brandId, brandName, category, reviewerName, reviewText, verdict } = payload;

    if (!brandName || !reviewerName || !reviewText) {
      return res.status(400).json({ error: "Missing required fields" });
    }

    const { data, error } = await supabase
      .from("reviews")
      .insert([
        {
          brand_id: brandId || null,
          brand_name: brandName,
          category: category || null,
          reviewer_name: reviewerName,
          review_text: reviewText,
          verdict: verdict || null
        }
      ])
      .select()
      .single();

    if (error) {
      console.error("Supabase insert error:", error);
      return res.status(500).json({ error: "Failed to save review" });
    }

    res.status(200).json({ ok: true, review: data });
  } catch (e) {
    console.error("Handler error:", e);
    res.status(500).json({ error: "Server error" });
  }
}
