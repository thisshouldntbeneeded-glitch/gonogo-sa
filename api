// api/submit-review.js
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
const supabaseServiceKey = process.env.SUPABASE_SERVICE_ROLE_KEY; // secret

const supabase = createClient(supabaseUrl, supabaseServiceKey);

export default async function handler(req, res) {
  // CORS: allow your deployed front-end
  res.setHeader('Access-Control-Allow-Origin', 'https://gonogo-sa.vercel.app');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');

  if (req.method === 'OPTIONS') {
    return res.status(200).end();
  }

  if (req.method !== 'POST') {
    res.setHeader('Allow', 'POST');
    return res.status(405).json({ error: 'Method not allowed' });
  }

  try {
    let payload = req.body;
    if (typeof payload === 'string') {
      payload = JSON.parse(payload || '{}');
    }

    const { brandId, brandName, category, reviewerName, reviewText, verdict } = payload;

    if (!brandName || !reviewerName || !reviewText) {
      return res.status(400).json({ error: 'Missing required fields' });
    }

    const { data, error } = await supabase
      .from('reviews')
      .insert({
        brand_id: brandId || null,
        brand_name: brandName,
        category: category || null,
        reviewer_name: reviewerName,
        review_text: reviewText,
        verdict: verdict || 'go',
        status: 'pending'
      })
      .select()
      .single();

    if (error) throw error;

    return res.status(200).json({ success: true, review: data });
  } catch (err) {
    console.error('submit-review error', err);
    return res.status(500).json({ error: 'Server error' });
  }
}
