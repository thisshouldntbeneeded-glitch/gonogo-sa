{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/brand.html", "has": [{ "type": "query", "key": "id", "value": "(?<slug>.*)" }], "destination": "/brand/:slug", "statusCode": 301 },
    { "source": "/brand",      "has": [{ "type": "query", "key": "id", "value": "(?<slug>.*)" }], "destination": "/brand/:slug", "statusCode": 301 },
    { "source": "/category.html", "has": [{ "type": "query", "key": "cat",  "value": "(?<slug>.*)" }], "destination": "/category/:slug", "statusCode": 301 },
    { "source": "/category.html", "has": [{ "type": "query", "key": "slug", "value": "(?<slug>.*)" }], "destination": "/category/:slug", "statusCode": 301 },
    { "source": "/category",      "has": [{ "type": "query", "key": "cat",  "value": "(?<slug>.*)" }], "destination": "/category/:slug", "statusCode": 301 },
    { "source": "/category",      "has": [{ "type": "query", "key": "slug", "value": "(?<slug>.*)" }], "destination": "/category/:slug", "statusCode": 301 },
    { "source": "/blog-post.html", "has": [{ "type": "query", "key": "slug", "value": "(?<slug>.*)" }], "destination": "/blog/:slug", "statusCode": 301 },
    { "source": "/blog-post",      "has": [{ "type": "query", "key": "slug", "value": "(?<slug>.*)" }], "destination": "/blog/:slug", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/brand/:slug", "destination": "/brand.html?id=:slug" },
    { "source": "/category/:slug", "destination": "/category.html?cat=:slug" },
    { "source": "/blog/:slug", "destination": "/blog-post.html?slug=:slug" },
    { "source": "/compare", "destination": "/compare.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/cookies", "destination": "/cookies.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin-brands", "destination": "/admin-brands.html" },
    { "source": "/admin-comments", "destination": "/admin-comments.html" },
    { "source": "/admin-research", "destination": "/admin-research.html" },
    { "source": "/admin-settings", "destination": "/admin-settings.html" },
    { "source": "/admin-api", "destination": "/admin-api.html" },
    { "source": "/brand-dashboard", "destination": "/brand-dashboard.html" },
    { "source": "/brand-reviews", "destination": "/brand-reviews.html" },
    { "source": "/brand-insights", "destination": "/brand-insights.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/auth/reset", "destination": "/auth/reset.html" },
    { "source": "/admin-scoring", "destination": "/admin-scoring.html" },
    { "source": "/admin-users", "destination": "/admin-users.html" },
    { "source": "/brand-cx", "destination": "/brand-cx.html" },
    { "source": "/brand-cx-surveys", "destination": "/brand-cx-surveys.html" },
    { "source": "/brand-cx-responses", "destination": "/brand-cx-responses.html" },
    { "source": "/brand-cx-case", "destination": "/brand-cx-case.html" },
    { "source": "/brand-cx-survey-edit", "destination": "/brand-cx-survey-edit.html" },
    { "source": "/cx-survey", "destination": "/cx-survey.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co https://www.google-analytics.com https://region1.google-analytics.com https://cdn.jsdelivr.net; frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=1800" }
      ]
    },
    {
      "source": "/logos/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
