<!DOCTYPE html>
<html lang="en-ZA">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>GoNoGo SA Admin - Internal Feedback</title>

  <link rel="icon" href="favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png" />
  <link rel="apple-touch-icon" href="apple-touch-icon.png" />
  <link rel="manifest" href="site.webmanifest" />
  <link rel="stylesheet" href="style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <style>
    .feedback-shell {
      display: grid;
      gap: var(--space-6);
    }

    .feedback-topbar {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--space-4);
      flex-wrap: wrap;
      margin-bottom: var(--space-2);
    }

    .feedback-actions {
      display: flex;
      gap: var(--space-3);
      flex-wrap: wrap;
    }

    .feedback-filters {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr 0.8fr auto;
      gap: var(--space-4);
      align-items: end;
    }

    .field-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .field-label {
      font-size: var(--text-xs);
      font-weight: 700;
      color: var(--text-muted);
      letter-spacing: 0.02em;
    }

    .field-input,
    .field-select,
    .field-textarea {
      width: 100%;
      border: 1px solid var(--border-primary);
      background: var(--surface-2);
      color: var(--text-primary);
      border-radius: var(--radius-md);
      padding: 12px 14px;
      font-size: var(--text-sm);
      outline: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    .field-input:focus,
    .field-select:focus,
    .field-textarea:focus {
      border-color: rgba(17,165,81,0.45);
      box-shadow: 0 0 0 3px rgba(17,165,81,0.12);
      background: var(--surface-1);
    }

    .field-textarea {
      min-height: 120px;
      resize: vertical;
      line-height: 1.55;
    }

    .feedback-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-4);
    }

    .feedback-stat {
      border: 1px solid var(--border-primary);
      background: var(--surface-2);
      border-radius: var(--radius-lg);
      padding: var(--space-4);
    }

    .feedback-stat-label {
      font-size: var(--text-xs);
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    .feedback-stat-value {
      font-size: clamp(1.4rem, 1.15rem + 0.75vw, 2rem);
      line-height: 1;
      font-weight: 800;
      color: var(--text-primary);
      font-variant-numeric: tabular-nums;
    }

    .feedback-stat-note {
      margin-top: 8px;
      font-size: var(--text-xs);
      color: var(--text-secondary);
    }

    .feedback-table-wrap {
      overflow-x: auto;
    }

    .feedback-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 980px;
    }

    .feedback-table th,
    .feedback-table td {
      padding: 14px 12px;
      border-bottom: 1px solid var(--border-primary);
      vertical-align: top;
      text-align: left;
    }

    .feedback-table th {
      font-size: var(--text-xs);
      color: var(--text-muted);
      font-weight: 800;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .feedback-title {
      font-size: var(--text-sm);
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 6px;
    }

    .feedback-meta {
      font-size: var(--text-xs);
      color: var(--text-secondary);
      line-height: 1.5;
    }

    .feedback-body {
      font-size: var(--text-xs);
      color: var(--text-secondary);
      line-height: 1.6;
      max-width: 42ch;
      white-space: pre-wrap;
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .mini-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      border: 1px solid var(--border-primary);
      background: var(--surface-3);
      color: var(--text-secondary);
      white-space: nowrap;
    }

    .mini-badge.active {
      background: rgba(17,165,81,0.12);
      color: #11a551;
      border-color: rgba(17,165,81,0.25);
    }

    .mini-badge.archived {
      background: rgba(148,163,184,0.12);
      color: var(--text-muted);
    }

    .mini-badge.general { background: rgba(59,130,246,0.12); color: #3b82f6; border-color: rgba(59,130,246,0.24); }
    .mini-badge.complaint { background: rgba(231,76,60,0.12); color: #e74c3c; border-color: rgba(231,76,60,0.24); }
    .mini-badge.compliment { background: rgba(17,165,81,0.12); color: #11a551; border-color: rgba(17,165,81,0.24); }
    .mini-badge.staff { background: rgba(139,92,246,0.12); color: #8b5cf6; border-color: rgba(139,92,246,0.24); }
    .mini-badge.product { background: rgba(245,158,11,0.12); color: #f59e0b; border-color: rgba(245,158,11,0.24); }
    .mini-badge.service { background: rgba(14,165,233,0.12); color: #0ea5e9; border-color: rgba(14,165,233,0.24); }
    .mini-badge.ops { background: rgba(107,114,128,0.14); color: #6b7280; border-color: rgba(107,114,128,0.24); }

    .row-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .btn-ghost {
      background: var(--surface-3);
      color: var(--text-secondary);
      border: 1px solid var(--border-primary);
    }

    .btn-ghost:hover {
      background: var(--surface-1);
      color: var(--text-primary);
    }

    .btn-danger-soft {
      background: rgba(231,76,60,0.10);
      color: #e74c3c;
      border: 1px solid rgba(231,76,60,0.20);
    }

    .btn-danger-soft:hover {
      background: rgba(231,76,60,0.16);
    }

    .empty-state-soft {
      padding: var(--space-8);
      text-align: center;
      border: 1px dashed var(--border-primary);
      border-radius: var(--radius-lg);
      background: var(--surface-2);
      color: var(--text-muted);
    }

    .loading-state {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-3);
      padding: var(--space-8);
      color: var(--text-muted);
      font-size: var(--text-sm);
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.45);
      display: none;
      align-items: center;
      justify-content: center;
      padding: var(--space-4);
      z-index: 1200;
    }

    .modal-backdrop.open {
      display: flex;
    }

    .modal-card {
      width: min(920px, 100%);
      max-height: calc(100vh - 40px);
      overflow: auto;
      border-radius: var(--radius-xl);
      border: 1px solid var(--border-primary);
      background: var(--surface-1);
      box-shadow: 0 30px 60px rgba(0,0,0,0.20);
    }

    .modal-header,
    .modal-footer {
      padding: var(--space-5);
      border-bottom: 1px solid var(--border-primary);
    }

    .modal-footer {
      border-bottom: none;
      border-top: 1px solid var(--border-primary);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-3);
      flex-wrap: wrap;
    }

    .modal-body {
      padding: var(--space-5);
      display: grid;
      gap: var(--space-5);
    }

    .modal-title {
      font-size: var(--text-lg);
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 6px;
    }

    .modal-subtitle {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      max-width: none;
    }

    .modal-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
    }

    .modal-grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
    }

    .toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      border: 1px solid var(--border-primary);
      background: var(--surface-2);
      border-radius: var(--radius-md);
      padding: 12px 14px;
    }

    .toggle-row-copy strong {
      display: block;
      font-size: var(--text-sm);
      color: var(--text-primary);
      margin-bottom: 4px;
    }

    .toggle-row-copy span {
      display: block;
      font-size: var(--text-xs);
      color: var(--text-secondary);
      line-height: 1.5;
    }

    .form-help {
      font-size: var(--text-xs);
      color: var(--text-muted);
      line-height: 1.5;
      margin-top: 8px;
    }

    .hidden {
      display: none !important;
    }

    @media (max-width: 1100px) {
      .feedback-filters,
      .feedback-stats,
      .modal-grid,
      .modal-grid-3 {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 768px) {
      .feedback-filters,
      .feedback-stats,
      .modal-grid,
      .modal-grid-3 {
        grid-template-columns: 1fr;
      }

      .feedback-topbar,
      .modal-footer {
        flex-direction: column;
        align-items: stretch;
      }
    }
  </style>
</head>
<body>
  <div class="admin-layout">
    <div id="sidebar-container"></div>

    <main class="admin-main" id="admin-content" style="display:none;">
      <div class="admin-header">
        <div>
          <h1 class="admin-title">Internal feedback</h1>
          <p class="text-sm text-secondary">Private feedback for brands that does not appear on the public GoNoGo website.</p>
        </div>

        <div class="feedback-actions">
          <button class="btn btn-sm btn-ghost" onclick="refreshFeedback()">
            <i class="fa-solid fa-rotate-right"></i>
            Refresh
          </button>
          <button class="btn btn-primary btn-sm" onclick="openCreateModal()">
            <i class="fa-solid fa-plus"></i>
            Add internal feedback
          </button>
        </div>
      </div>

      <div class="feedback-shell">
        <section class="card">
          <div class="feedback-filters">
            <div class="field-group">
              <label class="field-label" for="filter-brand-slug">Brand slug</label>
              <input id="filter-brand-slug" class="field-input" type="text" placeholder="e.g. takealot" />
            </div>

            <div class="field-group">
              <label class="field-label" for="filter-status">Status</label>
              <select id="filter-status" class="field-select">
                <option value="">All statuses</option>
                <option value="active">Active</option>
                <option value="archived">Archived</option>
              </select>
            </div>

            <div class="field-group">
              <label class="field-label" for="filter-type">Type</label>
              <select id="filter-type" class="field-select">
                <option value="">All types</option>
                <option value="general">General</option>
                <option value="complaint">Complaint</option>
                <option value="compliment">Compliment</option>
                <option value="staff">Staff</option>
                <option value="product">Product</option>
                <option value="service">Service</option>
                <option value="ops">Ops</option>
              </select>
            </div>

            <div class="field-group">
              <button class="btn btn-primary" onclick="applyFilters()">
                <i class="fa-solid fa-filter"></i>
                Apply filters
              </button>
            </div>
          </div>
        </section>

        <section class="feedback-stats" id="feedback-stats">
          <div class="feedback-stat">
            <div class="feedback-stat-label">Total items</div>
            <div class="feedback-stat-value" id="stat-total">0</div>
            <div class="feedback-stat-note">All internal feedback currently loaded</div>
          </div>
          <div class="feedback-stat">
            <div class="feedback-stat-label">Active</div>
            <div class="feedback-stat-value" id="stat-active">0</div>
            <div class="feedback-stat-note">Visible in admin workflows</div>
          </div>
          <div class="feedback-stat">
            <div class="feedback-stat-label">Archived</div>
            <div class="feedback-stat-value" id="stat-archived">0</div>
            <div class="feedback-stat-note">Kept for record but not active</div>
          </div>
          <div class="feedback-stat">
            <div class="feedback-stat-label">Visible to brand</div>
            <div class="feedback-stat-value" id="stat-visible">0</div>
            <div class="feedback-stat-note">Safe to show later in brand portal</div>
          </div>
        </section>

        <section class="card">
          <div class="section-header-row">
            <div class="section-header-copy">
              <h3 class="text-sm font-semibold" style="margin-bottom:6px;">
                <i class="fa-solid fa-lock" style="color:var(--green); margin-right: var(--space-2);"></i>
                Feedback records
              </h3>
              <p class="text-xs text-muted">These notes stay internal and are separate from public website reviews.</p>
            </div>
            <div class="text-xs text-muted" id="feedback-count-copy">Loading feedback...</div>
          </div>

          <div id="feedback-table-shell">
            <div class="loading-state">
              <i class="fa-solid fa-spinner fa-spin"></i>
              <span>Loading internal feedback...</span>
            </div>
          </div>
        </section>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="feedback-modal">
    <div class="modal-card">
      <div class="modal-header">
        <div class="modal-title" id="modal-title">Add internal feedback</div>
        <div class="modal-subtitle" id="modal-subtitle">Capture private feedback for a brand without affecting the public website.</div>
      </div>

      <div class="modal-body">
        <input type="hidden" id="form-feedback-id" />

        <div class="modal-grid">
          <div class="field-group">
            <label class="field-label" for="form-brand-slug">Brand slug</label>
            <input id="form-brand-slug" class="field-input" type="text" placeholder="e.g. takealot" />
          </div>

          <div class="field-group">
            <label class="field-label" for="form-title">Title</label>
            <input id="form-title" class="field-input" type="text" placeholder="Short internal headline" />
          </div>
        </div>

        <div class="field-group">
          <label class="field-label" for="form-feedback-text">Feedback text</label>
          <textarea id="form-feedback-text" class="field-textarea" placeholder="Write the internal feedback here..."></textarea>
        </div>

        <div class="modal-grid-3">
          <div class="field-group">
            <label class="field-label" for="form-feedback-type">Type</label>
            <select id="form-feedback-type" class="field-select">
              <option value="general">General</option>
              <option value="complaint">Complaint</option>
              <option value="compliment">Compliment</option>
              <option value="staff">Staff</option>
              <option value="product">Product</option>
              <option value="service">Service</option>
              <option value="ops">Ops</option>
            </select>
          </div>

          <div class="field-group">
            <label class="field-label" for="form-source">Source</label>
            <select id="form-source" class="field-select">
              <option value="internal">Internal</option>
              <option value="email">Email</option>
              <option value="call">Call</option>
              <option value="whatsapp">WhatsApp</option>
              <option value="in_person">In person</option>
              <option value="survey">Survey</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="field-group">
            <label class="field-label" for="form-rating">Rating</label>
            <select id="form-rating" class="field-select">
              <option value="">No rating</option>
              <option value="1">1 / 5</option>
              <option value="2">2 / 5</option>
              <option value="3">3 / 5</option>
              <option value="4">4 / 5</option>
              <option value="5">5 / 5</option>
            </select>
          </div>
        </div>

        <div class="modal-grid">
          <div class="field-group">
            <label class="field-label" for="form-customer-name">Customer name</label>
            <input id="form-customer-name" class="field-input" type="text" placeholder="Optional" />
          </div>

          <div class="field-group">
            <label class="field-label" for="form-location-label">Location / branch</label>
            <input id="form-location-label" class="field-input" type="text" placeholder="Optional" />
          </div>
        </div>

        <div class="modal-grid">
          <div class="field-group">
            <label class="field-label" for="form-customer-email">Customer email</label>
            <input id="form-customer-email" class="field-input" type="email" placeholder="Optional" />
          </div>

          <div class="field-group">
            <label class="field-label" for="form-customer-phone">Customer phone</label>
            <input id="form-customer-phone" class="field-input" type="text" placeholder="Optional" />
          </div>
        </div>

        <div class="field-group">
          <label class="field-label" for="form-internal-notes">Internal notes</label>
          <textarea id="form-internal-notes" class="field-textarea" placeholder="Optional admin-only notes"></textarea>
          <div class="form-help">Use this for internal handling context, next actions, or escalation notes.</div>
        </div>

        <div class="modal-grid">
          <div class="toggle-row">
            <div class="toggle-row-copy">
              <strong>Visible to brand</strong>
              <span>If enabled, this item can later be shown in the brand portal when we add that page.</span>
            </div>
            <input id="form-visible-to-brand" type="checkbox" checked />
          </div>

          <div class="field-group" id="form-status-wrap">
            <label class="field-label" for="form-status">Status</label>
            <select id="form-status" class="field-select">
              <option value="active">Active</option>
              <option value="archived">Archived</option>
            </select>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <div class="text-xs text-muted" id="modal-feedback-copy">Private feedback only. Not used on the public website.</div>
        <div style="display:flex; gap: var(--space-3); flex-wrap: wrap;">
          <button class="btn btn-sm btn-ghost" onclick="closeFeedbackModal()">Cancel</button>
          <button class="btn btn-primary btn-sm" id="save-feedback-btn" onclick="saveFeedback()">
            <i class="fa-solid fa-floppy-disk"></i>
            Save feedback
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="components.js"></script>
  <script src="api.js"></script>
  <script>
    Components.initTheme();

    var feedbackRows = [];
    var isSavingFeedback = false;

    document.getElementById('sidebar-container').innerHTML = Components.renderAdminSidebar('internal-feedback');

    if (!Components.checkAdminAuth()) {
      window.location.href = 'admin-login.html';
    } else {
      document.getElementById('admin-content').style.display = '';
      refreshFeedback();
    }

    function escapeHtml(value) {
      if (typeof Components !== 'undefined' && typeof Components.escapeHTML === 'function') {
        return Components.escapeHTML(value == null ? '' : String(value));
      }
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatDate(value) {
      if (!value) return '—';
      if (typeof Components !== 'undefined' && typeof Components.formatDate === 'function') {
        return Components.formatDate(value);
      }
      try {
        return new Date(value).toLocaleString();
      } catch (e) {
        return value;
      }
    }

    function truncateText(value, max) {
      value = value || '';
      if (value.length <= max) return value;
      return value.slice(0, max - 1) + '…';
    }

    function statusBadgeClass(status) {
      return status === 'archived' ? 'archived' : 'active';
    }

    function feedbackTypeClass(type) {
      var allowed = ['general', 'complaint', 'compliment', 'staff', 'product', 'service', 'ops'];
      return allowed.indexOf(type) !== -1 ? type : 'general';
    }

    function applyFilters() {
      refreshFeedback();
    }

    function getCurrentFilters() {
      return {
        brandSlug: (document.getElementById('filter-brand-slug').value || '').trim(),
        status: (document.getElementById('filter-status').value || '').trim(),
        feedbackType: (document.getElementById('filter-type').value || '').trim()
      };
    }

    function refreshFeedback() {
      var shell = document.getElementById('feedback-table-shell');
      shell.innerHTML = '<div class="loading-state"><i class="fa-solid fa-spinner fa-spin"></i><span>Loading internal feedback...</span></div>';

      if (!GoNoGoAPI || typeof GoNoGoAPI.getInternalFeedbackAdmin !== 'function') {
        shell.innerHTML = '<div class="empty-state-soft"><strong>API method missing.</strong><br>Please add the internal feedback methods to <code>api.js</code> next.</div>';
        return;
      }

      GoNoGoAPI.getInternalFeedbackAdmin(getCurrentFilters())
        .then(function (rows) {
          feedbackRows = Array.isArray(rows) ? rows : [];
          renderStats(feedbackRows);
          renderFeedbackTable(feedbackRows);
        })
        .catch(function (err) {
          console.error(err);
          shell.innerHTML = '<div class="empty-state-soft"><strong>Could not load internal feedback.</strong><br>Please check your API methods and Supabase permissions.</div>';
          document.getElementById('feedback-count-copy').textContent = 'Load failed';
        });
    }

    function renderStats(rows) {
      var total = rows.length;
      var active = rows.filter(function (r) { return r.status === 'active'; }).length;
      var archived = rows.filter(function (r) { return r.status === 'archived'; }).length;
      var visible = rows.filter(function (r) { return r.visibleToBrand; }).length;

      document.getElementById('stat-total').textContent = total;
      document.getElementById('stat-active').textContent = active;
      document.getElementById('stat-archived').textContent = archived;
      document.getElementById('stat-visible').textContent = visible;
      document.getElementById('feedback-count-copy').textContent = total + ' item' + (total === 1 ? '' : 's') + ' loaded';
    }

    function renderFeedbackTable(rows) {
      var shell = document.getElementById('feedback-table-shell');

      if (!rows.length) {
        shell.innerHTML = '<div class="empty-state-soft"><i class="fa-solid fa-lock" style="font-size: 26px; margin-bottom: 12px; opacity: 0.45;"></i><div>No internal feedback found for these filters.</div></div>';
        return;
      }

      var html = '';
      html += '<div class="feedback-table-wrap">';
      html += '<table class="feedback-table">';
      html += '<thead><tr>';
      html += '<th>Brand</th>';
      html += '<th>Feedback</th>';
      html += '<th>Tags</th>';
      html += '<th>Customer</th>';
      html += '<th>Created</th>';
      html += '<th>Actions</th>';
      html += '</tr></thead><tbody>';

      rows.forEach(function (row) {
        var ratingLabel = row.rating ? ('Rating ' + row.rating + '/5') : 'No rating';
        var customerBits = [];
        if (row.customerName) customerBits.push('<div>' + escapeHtml(row.customerName) + '</div>');
        if (row.customerEmail) customerBits.push('<div>' + escapeHtml(row.customerEmail) + '</div>');
        if (row.customerPhone) customerBits.push('<div>' + escapeHtml(row.customerPhone) + '</div>');
        if (row.locationLabel) customerBits.push('<div>' + escapeHtml(row.locationLabel) + '</div>');

        html += '<tr>';
        html += '<td>';
        html += '<div class="feedback-title">' + escapeHtml(row.brandSlug || '—') + '</div>';
        html += '<div class="feedback-meta">ID: ' + escapeHtml(row.id || '') + '</div>';
        html += '</td>';

        html += '<td>';
        html += '<div class="feedback-title">' + escapeHtml(row.title || 'Untitled') + '</div>';
        html += '<div class="feedback-body">' + escapeHtml(truncateText(row.feedbackText || '', 220)) + '</div>';
        if (row.internalNotes) {
          html += '<div class="feedback-meta" style="margin-top:8px;"><strong>Internal notes:</strong> ' + escapeHtml(truncateText(row.internalNotes, 120)) + '</div>';
        }
        html += '</td>';

        html += '<td>';
        html += '<div class="badge-row">';
        html += '<span class="mini-badge ' + statusBadgeClass(row.status) + '">' + escapeHtml(row.status || 'active') + '</span>';
        html += '<span class="mini-badge ' + feedbackTypeClass(row.feedbackType) + '">' + escapeHtml(row.feedbackType || 'general') + '</span>';
        html += '<span class="mini-badge">' + escapeHtml(row.source || 'internal') + '</span>';
        html += '<span class="mini-badge">' + escapeHtml(ratingLabel) + '</span>';
        html += '<span class="mini-badge">' + (row.visibleToBrand ? 'Visible to brand' : 'Admin only') + '</span>';
        html += '</div>';
        html += '</td>';

        html += '<td>';
        html += '<div class="feedback-meta">' + (customerBits.length ? customerBits.join('') : 'No customer details') + '</div>';
        html += '</td>';

        html += '<td>';
        html += '<div class="feedback-meta">' + escapeHtml(formatDate(row.createdAt)) + '</div>';
        if (row.updatedAt && row.updatedAt !== row.createdAt) {
          html += '<div class="feedback-meta" style="margin-top:6px;">Updated: ' + escapeHtml(formatDate(row.updatedAt)) + '</div>';
        }
        html += '</td>';

        html += '<td>';
        html += '<div class="row-actions">';
        html += '<button class="btn btn-sm btn-ghost" onclick="openEditModal(\'' + escapeHtml(row.id) + '\')"><i class="fa-solid fa-pen"></i> Edit</button>';
        if (row.status === 'archived') {
          html += '<button class="btn btn-sm btn-ghost" onclick="quickToggleArchive(\'' + escapeHtml(row.id) + '\', false)"><i class="fa-solid fa-box-open"></i> Unarchive</button>';
        } else {
          html += '<button class="btn btn-sm btn-danger-soft" onclick="quickToggleArchive(\'' + escapeHtml(row.id) + '\', true)"><i class="fa-solid fa-box-archive"></i> Archive</button>';
        }
        html += '</div>';
        html += '</td>';

        html += '</tr>';
      });

      html += '</tbody></table></div>';
      shell.innerHTML = html;
    }

    function resetForm() {
      document.getElementById('form-feedback-id').value = '';
      document.getElementById('form-brand-slug').value = '';
      document.getElementById('form-title').value = '';
      document.getElementById('form-feedback-text').value = '';
      document.getElementById('form-feedback-type').value = 'general';
      document.getElementById('form-source').value = 'internal';
      document.getElementById('form-status').value = 'active';
      document.getElementById('form-rating').value = '';
      document.getElementById('form-customer-name').value = '';
      document.getElementById('form-customer-email').value = '';
      document.getElementById('form-customer-phone').value = '';
      document.getElementById('form-location-label').value = '';
      document.getElementById('form-internal-notes').value = '';
      document.getElementById('form-visible-to-brand').checked = true;
    }

    function openCreateModal() {
      resetForm();
      document.getElementById('modal-title').textContent = 'Add internal feedback';
      document.getElementById('modal-subtitle').textContent = 'Capture private feedback for a brand without affecting the public website.';
      document.getElementById('form-status-wrap').classList.add('hidden');
      document.getElementById('feedback-modal').classList.add('open');
    }

    function openEditModal(id) {
      var row = feedbackRows.find(function (item) { return item.id === id; });
      if (!row) return;

      resetForm();
      document.getElementById('modal-title').textContent = 'Edit internal feedback';
      document.getElementById('modal-subtitle').textContent = 'Update the private feedback record or archive it for later reference.';
      document.getElementById('form-status-wrap').classList.remove('hidden');

      document.getElementById('form-feedback-id').value = row.id || '';
      document.getElementById('form-brand-slug').value = row.brandSlug || '';
      document.getElementById('form-title').value = row.title || '';
      document.getElementById('form-feedback-text').value = row.feedbackText || '';
      document.getElementById('form-feedback-type').value = row.feedbackType || 'general';
      document.getElementById('form-source').value = row.source || 'internal';
      document.getElementById('form-status').value = row.status || 'active';
      document.getElementById('form-rating').value = row.rating == null ? '' : String(row.rating);
      document.getElementById('form-customer-name').value = row.customerName || '';
      document.getElementById('form-customer-email').value = row.customerEmail || '';
      document.getElementById('form-customer-phone').value = row.customerPhone || '';
      document.getElementById('form-location-label').value = row.locationLabel || '';
      document.getElementById('form-internal-notes').value = row.internalNotes || '';
      document.getElementById('form-visible-to-brand').checked = row.visibleToBrand !== false;

      document.getElementById('feedback-modal').classList.add('open');
    }

    function closeFeedbackModal() {
      document.getElementById('feedback-modal').classList.remove('open');
    }

    function getFormPayload() {
      var ratingRaw = (document.getElementById('form-rating').value || '').trim();

      return {
        brandSlug: (document.getElementById('form-brand-slug').value || '').trim(),
        title: (document.getElementById('form-title').value || '').trim(),
        feedbackText: (document.getElementById('form-feedback-text').value || '').trim(),
        feedbackType: (document.getElementById('form-feedback-type').value || '').trim(),
        source: (document.getElementById('form-source').value || '').trim(),
        status: (document.getElementById('form-status').value || 'active').trim(),
        rating: ratingRaw ? parseInt(ratingRaw, 10) : null,
        customerName: (document.getElementById('form-customer-name').value || '').trim(),
        customerEmail: (document.getElementById('form-customer-email').value || '').trim(),
        customerPhone: (document.getElementById('form-customer-phone').value || '').trim(),
        locationLabel: (document.getElementById('form-location-label').value || '').trim(),
        internalNotes: (document.getElementById('form-internal-notes').value || '').trim(),
        visibleToBrand: !!document.getElementById('form-visible-to-brand').checked
      };
    }

    function validatePayload(payload, isEdit) {
      if (!isEdit && !payload.brandSlug) {
        alert('Please add a brand slug.');
        return false;
      }
      if (!payload.title) {
        alert('Please add a title.');
        return false;
      }
      if (!payload.feedbackText) {
        alert('Please add the feedback text.');
        return false;
      }
      return true;
    }

    function saveFeedback() {
      if (isSavingFeedback) return;
      if (!GoNoGoAPI) {
        alert('GoNoGoAPI is not available.');
        return;
      }

      var id = (document.getElementById('form-feedback-id').value || '').trim();
      var isEdit = !!id;
      var payload = getFormPayload();

      if (!validatePayload(payload, isEdit)) return;

      if (isEdit && typeof GoNoGoAPI.updateInternalFeedbackAdmin !== 'function') {
        alert('updateInternalFeedbackAdmin is not available in api.js yet.');
        return;
      }
      if (!isEdit && typeof GoNoGoAPI.createInternalFeedbackAdmin !== 'function') {
        alert('createInternalFeedbackAdmin is not available in api.js yet.');
        return;
      }

      isSavingFeedback = true;
      var saveBtn = document.getElementById('save-feedback-btn');
      var oldHtml = saveBtn.innerHTML;
      saveBtn.disabled = true;
      saveBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

      var promise = isEdit
        ? GoNoGoAPI.updateInternalFeedbackAdmin(id, payload)
        : GoNoGoAPI.createInternalFeedbackAdmin(payload);

      promise
        .then(function () {
          closeFeedbackModal();
          refreshFeedback();
        })
        .catch(function (err) {
          console.error(err);
          alert('Could not save internal feedback. Please check the API methods and try again.');
        })
        .finally(function () {
          isSavingFeedback = false;
          saveBtn.disabled = false;
          saveBtn.innerHTML = oldHtml;
        });
    }

    function quickToggleArchive(id, archiveNow) {
      var row = feedbackRows.find(function (item) { return item.id === id; });
      if (!row) return;

      if (typeof GoNoGoAPI.updateInternalFeedbackAdmin !== 'function') {
        alert('updateInternalFeedbackAdmin is not available in api.js yet.');
        return;
      }

      var payload = {
        title: row.title,
        feedbackText: row.feedbackText,
        feedbackType: row.feedbackType,
        source: row.source,
        status: archiveNow ? 'archived' : 'active',
        rating: row.rating,
        customerName: row.customerName,
        customerEmail: row.customerEmail,
        customerPhone: row.customerPhone,
        locationLabel: row.locationLabel,
        internalNotes: row.internalNotes,
        visibleToBrand: row.visibleToBrand
      };

      GoNoGoAPI.updateInternalFeedbackAdmin(id, payload)
        .then(function () {
          refreshFeedback();
        })
        .catch(function (err) {
          console.error(err);
          alert('Could not update archive status.');
        });
    }

    document.getElementById('feedback-modal').addEventListener('click', function (e) {
      if (e.target === this) closeFeedbackModal();
    });
  </script>
</body>
</html>
